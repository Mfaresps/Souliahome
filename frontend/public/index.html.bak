/* Profile */
function renderProfile() {
  if (!currentUser) {
    qs('#profile-avatar').innerHTML = '؟';
    qs('#prof-name').value = '';
    qs('#prof-username').value = '';
    qs('#prof-phone').value = '';
    qs('#prof-avatar').value = '';
    qs('#prof-password').value = '';
    return;
  }
  const avatarUrl = sanitizeUrl(currentUser.avatar);
  qs('#profile-avatar').innerHTML = avatarUrl ? `<img src="${esc(avatarUrl)}" style="width:100%;height:100%;border-radius:50%;object-fit:cover">` : esc((currentUser.name || currentUser.username || '?').slice(0, 2));
  qs('#prof-name').value = currentUser.name || '';
  qs('#prof-username').value = currentUser.username || '';
  qs('#prof-phone').value = currentUser.phone || '';
  qs('#prof-avatar').value = currentUser.avatar || '';
  qs('#prof-password').value = '';
}
async function saveProfile() {
  if (!currentUser) { toast('خطأ: لم يتم تحميل ملف المستخدم', true); return; }
  const body = { phone: qs('#prof-phone').value, avatar: qs('#prof-avatar').value };
  const pass = qs('#prof-password').value; if (pass) body.password = pass;
  try {
    const userId = currentUser.id || currentUser._id;
    if (!userId) { toast('خطأ: لا يمكن تحديد معرف المستخدم', true); return; }
    await api('/users/' + userId, { method: 'PUT', body: JSON.stringify(body) });
    if (body.phone) currentUser.phone = body.phone; 
    if (body.avatar) currentUser.avatar = body.avatar;
    localStorage.setItem('user', JSON.stringify(currentUser)); 
    toast('تم حفظ التعديلات'); 
    updateHeader(); 
    renderProfile();
  } catch (e) { toast('خطأ: ' + e.message, true); }
}

/* Modal */
function openModal(html, style) {
  qs('#modal-content').innerHTML = html;
  qs('#modal-content').style.cssText = style || '';
  qs('#modal-overlay').classList.add('active');
}
function closeModal() { qs('#modal-overlay').classList.remove('active'); }

/**
 * Collects root and descendants in pre-order (parent before children).
 * @param {Element} root
 * @returns {Element[]}
 */
function collectElementsPreOrder(root) {
  const out = [];
  function visit(node) {
    out.push(node);
    const ch = node.children;
    for (let i = 0; i < ch.length; i++) visit(ch[i]);
  }
  visit(root);
  return out;
}

/**
 * @param {Element} el
 * @returns {boolean}
 */
function isSubmitButtonVisible(el) {
  if (!el || el.tagName !== 'BUTTON' || el.disabled) return false;
  if (!el.classList.contains('btn') || !el.classList.contains('btn-primary')) return false;
  const st = window.getComputedStyle(el);
  return st.display !== 'none' && st.visibility !== 'hidden';
}

/**
 * Resolves the DOM subtree used to find a primary submit for Enter-to-submit.
 * @param {Element} el
 * @returns {Element|null}
 */
function getEnterSubmitScopeRoot(el) {
  const modal = el.closest('#modal-content');
  if (modal && qs('#modal-overlay').classList.contains('active')) return modal;
  if (el.closest('#inv-detail-content') && qs('#inv-detail-overlay').classList.contains('active')) return qs('#inv-detail-content');
  const loginBox = el.closest('.login-box');
  if (loginBox) {
    const lp = qs('#login-page');
    if (lp && lp.style.display !== 'none') return loginBox;
  }
  const vaultLocked = el.closest('#vault-locked');
  if (vaultLocked) {
    const vl = qs('#vault-locked');
    if (vl && window.getComputedStyle(vl).display !== 'none') return vaultLocked;
  }
  if (el.closest('.profile-section')) return el.closest('.profile-section');
  const txPage = qs('#page-transaction');
  if (txPage && txPage.classList.contains('active') && el.closest('#page-transaction')) return txPage;
  const card = el.closest('.card');
  if (card && el.closest('.page.active')) return card;
  return null;
}

/**
 * Finds the first visible primary button after the field within scope (footer submit).
 * @param {Element} field
 * @param {Element} root
 * @returns {HTMLButtonElement|null}
 */
function findPrimarySubmitAfterField(field, root) {
  if (root.id === 'page-transaction') {
    const b = qs('#tx-save-btn');
    return isSubmitButtonVisible(b) ? b : null;
  }
  const ordered = collectElementsPreOrder(root);
  const idx = ordered.indexOf(field);
  if (idx < 0) return null;
  for (let i = idx + 1; i < ordered.length; i++) {
    const n = ordered[i];
    if (isSubmitButtonVisible(n)) return n;
  }
  return null;
}

/**
 * Submits the current logical form when pressing Enter in a field (modals, login, cards, transaction page).
 * @param {KeyboardEvent} e
 * @returns {void}
 */
function handleEnterToSubmit(e) {
  if (e.key !== 'Enter' || e.defaultPrevented) return;
  const t = e.target;
  if (!t || !t.closest) return;
  if (t.id === 'global-search') return;
  if (t.closest('#calc-widget')) return;
  const acWrap = t.closest('.ac-wrap');
  if (acWrap) {
    const acList = acWrap.querySelector('.ac-list');
    if (acList && acList.classList.contains('show')) return;
  }
  const tag = t.tagName;
  if (tag === 'TEXTAREA') {
    if (!(e.ctrlKey || e.metaKey)) return;
  } else if (tag === 'INPUT') {
    const type = (t.getAttribute('type') || 'text').toLowerCase();
    if (['checkbox', 'radio', 'file', 'button', 'submit', 'reset', 'hidden'].includes(type)) return;
  } else if (tag === 'SELECT') {
    /* allow */
  } else {
    return;
  }
  if (t.id === 'set-cairo-price' || t.id === 'set-gov-price') {
    e.preventDefault();
    saveDefaultPrices();
    return;
  }
  const root = getEnterSubmitScopeRoot(t);
  if (!root) return;
  const btn = findPrimarySubmitAfterField(t, root);
  if (!btn) return;
  e.preventDefault();
  btn.click();
}

document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') {
    if (qs('#inv-detail-overlay').classList.contains('active')) closeInvoiceDetail();
    else if (qs('#modal-overlay').classList.contains('active')) closeModal();
  } else if (e.key === 'Enter') {
    handleEnterToSubmit(e);
  }
});

/* Global Search */
let searchSelectedIdx = -1;
let searchResults = [];
let searchAbort = null;

function buildNavSearchItems(q) {
  const raw = String(q || '').trim();
  const nq = normalizeUiSearch(raw);
  if (!nq) {
    return [];
  }
  const tokens = nq.split(/\s+/).filter(Boolean);
  return NAV_ITEMS.filter(n => hasPerm(n.perm)).filter(n => {
    const blob = normalizeUiSearch([n.label, n.labelEn || '', PERMS_AR[n.perm] || '', n.id].join(' '));
    return tokens.every(t => blob.includes(t));
  }).map(n => ({
    id: n.id,
    type: 'nav',
    title: n.label,
    subtitle: [n.labelEn, PERMS_AR[n.perm]].filter(Boolean).join(' — '),
    icon: n.icon,
    meta: 'انتقال',
  }));
}

function openSearchDropdown(html) {
  const dd = qs('#search-dropdown');
  dd.innerHTML = html;
  dd.classList.add('active');
}

function closeSearchDropdown() {
  const dd = qs('#search-dropdown');
  dd.classList.remove('active');
  dd.innerHTML = '';
  searchSelectedIdx = -1;
  searchResults = [];
}

async function handleGlobalSearch(q) {
  const raw = String(q || '').trim();
  if (!raw) {
    closeSearchDropdown();
    return;
  }
  if (searchAbort) {
    searchAbort.abort();
  }
  searchAbort = new AbortController();
  openSearchDropdown('<div class="search-loading">جاري البحث...</div>');
  try {
    const data = await api('/search?q=' + encodeURIComponent(raw), { signal: searchAbort.signal });
    searchAbort = null;
    const navPart = buildNavSearchItems(raw);
    searchResults = [...navPart, ...(data.results || [])];
    searchSelectedIdx = -1;
    if (!searchResults.length) {
      openSearchDropdown('<div class="search-empty">لم يتم العثور على نتائج</div>');
      return;
    }
    renderSearchDropdown();
  } catch (e) {
    if (e.name === 'AbortError') {
      return;
    }
    openSearchDropdown('<div class="search-empty">خطأ في البحث</div>');
  }
}

function renderSearchDropdown() {
  const categories = {
    nav: 'الأقسام',
    product: 'الأصناف',
    customer: 'العملاء',
    order: 'الحركات والطلبات',
    supplier: 'الموردون',
  };
  const preferred = ['nav', 'product', 'customer', 'order', 'supplier'];
  const grouped = {};
  searchResults.forEach((r, idx) => {
    r._idx = idx;
    if (!grouped[r.type]) {
      grouped[r.type] = [];
    }
    grouped[r.type].push(r);
  });
  let html = '';
  const keys = [
    ...preferred.filter(k => grouped[k]?.length),
    ...Object.keys(grouped).filter(k => !preferred.includes(k) && grouped[k]?.length),
  ];
  for (const type of keys) {
    const items = grouped[type];
    if (!items || !items.length) {
      continue;
    }
    html += '<div class="search-category">' + esc(categories[type] || type) + '</div>';
    for (const item of items) {
      const isSelected = item._idx === searchSelectedIdx;
      html += '<div class="search-item' + (isSelected ? ' selected' : '') + '" data-idx="' + item._idx + '" onmousedown="selectSearchResult(' + item._idx + ')">'
        + '<span class="search-icon">' + item.icon + '</span>'
        + '<div class="search-info"><div class="search-title">' + esc(item.title) + '</div><div class="search-subtitle">' + esc(item.subtitle) + '</div></div>'
        + (item.meta ? '<span class="search-meta">' + esc(item.meta) + '</span>' : '')
        + '</div>';
    }
  }
  html += '<div class="search-hint">عدة كلمات، عربي/إنجليزي، مرجع مع # أو بدونه — تمرير لعرض المزيد</div>';
  openSearchDropdown(html);
}

function selectSearchResult(idx) {
  const item = searchResults[idx];
  if (!item) {
    return;
  }
  closeSearchDropdown();
  qs('#global-search').value = '';
  if (item.type === 'nav') {
    navigateTo(item.id);
    closeSidebar();
    return;
  }
  if (item.type === 'product' && hasPerm('products')) {
    navigateTo('products');
    setTimeout(() => { const el = qs('#prod-search'); if (el) { el.value = item.title; renderProducts(); } }, 100);
  } else if (item.type === 'customer' && hasPerm('clients')) {
    navigateTo('clients');
    setTimeout(() => { const el = qs('#clients-search'); if (el) { el.value = item.title; renderClients(); } }, 100);
  } else if (item.type === 'order' && hasPerm('movements')) {
    navigateTo('movements');
    setTimeout(() => { const el = qs('#mov-search'); if (el) { el.value = item.title.replace('#', ''); renderMovements(); } }, 100);
  } else if (item.type === 'supplier' && hasPerm('suppliers')) {
    navigateTo('suppliers');
  }
}

function handleSearchKeydown(e) {
  const dd = qs('#search-dropdown');
  if (!dd.classList.contains('active') || !searchResults.length) return;
  if (e.key === 'ArrowDown') {
    e.preventDefault();
    searchSelectedIdx = Math.min(searchSelectedIdx + 1, searchResults.length - 1);
    renderSearchDropdown();
  } else if (e.key === 'ArrowUp') {
    e.preventDefault();
    searchSelectedIdx = Math.max(searchSelectedIdx - 1, 0);
    renderSearchDropdown();
  } else if (e.key === 'Enter' && searchSelectedIdx >= 0) {
    e.preventDefault();
    selectSearchResult(searchSelectedIdx);
  } else if (e.key === 'Escape') {
    closeSearchDropdown();
  }
}

document.addEventListener('click', function(e) {
  if (!e.target.closest('.header-search')) closeSearchDropdown();
});

const debouncedGlobalSearch = debounce(handleGlobalSearch, 300);

/* Excel helper */
function writeExcel(data, sheetName, fileName) {
  const ws = XLSX.utils.json_to_sheet(data);
  const wb = XLSX.utils.book_new();
  XLSX.utils.book_append_sheet(wb, ws, sheetName);
  XLSX.writeFile(wb, fileName + '.xlsx');
}

/* Calculator */
let calcCurrent = '0', calcPrev = '', calcOperator = '', calcHasResult = false;
function toggleCalc() { qs('#calc-widget').classList.toggle('open'); }
function updateCalcDisplay() {
  qs('#calc-result').textContent = calcCurrent;
  qs('#calc-expr').textContent = calcPrev ? calcPrev + ' ' + ({'/':'÷','*':'×','-':'−','+':'+'}[calcOperator] || '') : '';
}
function calcDigit(d) {
  if (calcHasResult) { calcCurrent = ''; calcHasResult = false; }
  if (calcCurrent === '0' && d !== '.') calcCurrent = '';
  calcCurrent += d;
  updateCalcDisplay();
}
function calcDot() {
  if (calcHasResult) { calcCurrent = '0'; calcHasResult = false; }
  if (!calcCurrent.includes('.')) calcCurrent += '.';
  updateCalcDisplay();
}
function calcOp(op) {
  if (calcPrev && calcOperator && !calcHasResult) calcEquals();
  calcPrev = calcCurrent || calcPrev;
  calcOperator = op;
  calcCurrent = '';
  calcHasResult = false;
  updateCalcDisplay();
}
function calcEquals() {
  if (!calcPrev || !calcOperator || calcCurrent === '') return;
  const a = parseFloat(calcPrev), b = parseFloat(calcCurrent);
  let r = 0;
  if (calcOperator === '+') r = a + b;
  else if (calcOperator === '-') r = a - b;
  else if (calcOperator === '*') r = a * b;
  else if (calcOperator === '/') r = b !== 0 ? a / b : 0;
  const display = parseFloat(r.toFixed(10)).toString();
  qs('#calc-expr').textContent = calcPrev + ' ' + ({'/':'÷','*':'×','-':'−','+':'+'}[calcOperator]) + ' ' + calcCurrent + ' =';
  calcCurrent = display;
  calcPrev = '';
  calcOperator = '';
  calcHasResult = true;
  qs('#calc-result').textContent = calcCurrent;
}
function calcClear() { calcCurrent = '0'; calcPrev = ''; calcOperator = ''; calcHasResult = false; updateCalcDisplay(); }
function calcBackspace() {
  if (calcHasResult) return;
  calcCurrent = calcCurrent.slice(0, -1) || '0';
  updateCalcDisplay();
}
function calcPercent() {
  if (!calcCurrent) return;
  calcCurrent = (parseFloat(calcCurrent) / 100).toString();
  updateCalcDisplay();
}
let calcDragging = false, calcOffX = 0, calcOffY = 0;
function startCalcDrag(e) {
  if (e.target.id === 'calc-close') return;
  calcDragging = true;
  const rect = qs('#calc-widget').getBoundingClientRect();
  calcOffX = e.clientX - rect.left;
  calcOffY = e.clientY - rect.top;
  document.addEventListener('mousemove', onCalcDrag);
  document.addEventListener('mouseup', stopCalcDrag);
}
function onCalcDrag(e) {
  if (!calcDragging) return;
  const w = qs('#calc-widget');
  w.style.left = Math.max(0, e.clientX - calcOffX) + 'px';
  w.style.top = Math.max(0, e.clientY - calcOffY) + 'px';
  w.style.bottom = 'auto';
  w.style.right = 'auto';
}
function stopCalcDrag() { calcDragging = false; document.removeEventListener('mousemove', onCalcDrag); document.removeEventListener('mouseup', stopCalcDrag); }

/* ===== COMPLAINTS ===== */
let cmpCharts = {};

async function loadComplaints() {
  try {
    complaints = await api('/complaints');
  } catch (_) { complaints = []; }
  // apply section title from settings
  const titleEl = qs('#complaints-section-title');
  if (titleEl && settings.complaintsTitle) titleEl.textContent = settings.complaintsTitle;
  renderComplaints();
  renderCmpCharts();
  renderCmpNegAlert();
}

function setCmpTab(tab, btn) {
  cmpTabFilter = tab;
  qsa('.tab-btn', qs('#page-complaints')).forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  if (tab !== 'all' && tab !== 'followup') {
    qs('#cmp-status-filter').value = tab;
  } else {
    qs('#cmp-status-filter').value = '';
  }
  renderComplaints();
}

function clearCmpFilters() {
  qs('#cmp-status-filter').value = '';
  qs('#cmp-emp-filter').value = '';
  qs('#cmp-from').value = '';
  qs('#cmp-to').value = '';
  qs('#cmp-search').value = '';
  cmpTabFilter = 'all';
  qsa('.tab-btn', qs('#page-complaints')).forEach(b => b.classList.remove('active'));
  qs('#cmp-tab-all').classList.add('active');
  renderComplaints();
}

function renderComplaints() {
  // populate employee filter
  const empSel = qs('#cmp-emp-filter');
  const empSet = new Set(complaints.map(c => c.submittedBy).filter(Boolean));
  const empVal = empSel.value;
  empSel.innerHTML = '<option value="">كل الموظفين</option>' + [...empSet].map(e => `<option value="${esc(e)}"${empVal===e?' selected':''}>${esc(e)}</option>`).join('');

  const statusF = qs('#cmp-status-filter').value;
  const empF = empSel.value;
  const fromF = qs('#cmp-from').value;
  const toF = qs('#cmp-to').value;
  const search = (qs('#cmp-search').value || '').toLowerCase();

  const cmpSortOrder = qs('#cmp-sort-order')?.value || 'desc';
  let data = complaints.filter(c => {
    if (cmpTabFilter === 'followup') { if (!c.inFollowUp) return false; }
    else if (statusF) { if (c.status !== statusF) return false; }
    if (empF && c.submittedBy !== empF) return false;
    const dStr = (c.createdAt || '').slice(0, 10);
    if (fromF && dStr < fromF) return false;
    if (toF && dStr > toF) return false;
    if (search) {
      const haystack = [c.complaintNo, c.clientName, c.submittedBy, c.description, c.transactionRef].join(' ').toLowerCase();
      if (!haystack.includes(search)) return false;
    }
    return true;
  });
  data.sort((a, b) => cmpSortOrder === 'asc'
    ? (a.createdAt||'').localeCompare(b.createdAt||'')
    : (b.createdAt||'').localeCompare(a.createdAt||''));


  // KPI
  const total = complaints.length;
  const pending = complaints.filter(c => c.status === 'معلق').length;
  const accepted = complaints.filter(c => c.status === 'مقبول').length;
  const rejected = complaints.filter(c => c.status === 'مرفوض').length;
  const rated = complaints.filter(c => c.surveyRating);
  const avgRating = rated.length ? (rated.reduce((s, c) => s + c.surveyRating, 0) / rated.length).toFixed(1) : '-';
  qs('#cmp-kpi').innerHTML = [
    { label: 'إجمالي الشكاوى', val: total, color: 'text-blue' },
    { label: 'معلقة', val: pending, color: 'text-orange' },
    { label: 'مقبولة', val: accepted, color: 'text-green' },
    { label: 'مرفوضة', val: rejected, color: 'text-red' },
    { label: 'متوسط التقييم', val: avgRating === '-' ? '-' : avgRating + ' ⭐', color: 'text-purple' },
    { label: 'معدل الحل', val: total ? Math.round((accepted + rejected) / total * 100) + '%' : '0%', color: 'text-green' },
  ].map(s => `<div class="card stat-card"><div class="stat-label">${esc(s.label)}</div><div class="stat-val ${s.color}">${esc(String(s.val))}</div></div>`).join('');

  const tbody = qs('#cmp-tbody');
  if (!data.length) {
    tbody.innerHTML = '<tr><td colspan="10" class="empty-state">لا توجد شكاوى</td></tr>';
    return;
  }
  tbody.innerHTML = data.map(c => {
    const statusBadge = c.status === 'مقبول'
      ? `<span class="badge badge-green">مقبول</span>`
      : c.status === 'مرفوض'
        ? `<span class="badge badge-red">مرفوض</span>`
        : `<span class="badge badge-orange">معلق</span>`;
    const ratingHtml = c.surveyRating ? '⭐'.repeat(c.surveyRating) : '<span class="text-muted">—</span>';
    const actionBadge = c.managerAction ? `<span class="badge badge-blue">${esc(c.managerAction)}</span>` : '<span class="text-muted">—</span>';
    const surveyLink = c.surveyToken && !c.surveyCompletedAt
      ? `<button class="btn btn-outline btn-xs" onclick="copySurveyLink('${esc(c.surveyToken)}')">📋 نسخ رابط</button>` : '';
    const resolveBtn = isAdmin() && c.status === 'معلق'
      ? `<button class="btn btn-primary btn-xs" onclick="openResolveModal('${c._id}')">قرار</button>` : '';
    const deleteBtn = isAdmin()
      ? `<button class="btn btn-danger btn-xs" onclick="deleteComplaint('${c._id}')">🗑</button>` : '';
    const viewBtn = `<button class="btn btn-outline btn-xs" onclick="viewComplaint('${c._id}')">عرض</button>`;
    const elapsedHtml = c.createdAt ? `<span style="font-size:.7rem;color:var(--muted)">${fmtElapsed(c.createdAt)}</span>` : '—';
    return `<tr>
      <td><span class="badge badge-blue">${esc(c.complaintNo)}</span></td>
      <td>${esc(c.submittedBy || '—')}</td>
      <td>${esc(c.clientName || '—')}</td>
      <td style="max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${esc(c.transactionRef || '—')}</td>
      <td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="${esc(c.description)}">${esc(c.description)}</td>
      <td>${statusBadge}</td>
      <td>${actionBadge}</td>
      <td>${fmtDate((c.createdAt || '').slice(0, 10))}<br>${elapsedHtml}</td>
      <td>${ratingHtml}</td>
      <td class="flex gap-4" style="gap:4px">${viewBtn}${resolveBtn}${surveyLink}${deleteBtn}</td>
    </tr>`;
  }).join('');
}

function renderCmpCharts() {
  // Status donut
  const statusCtx = qs('#cmp-chart-status');
  if (statusCtx) {
    if (cmpCharts.status) cmpCharts.status.destroy();
    const pending = complaints.filter(c => c.status === 'معلق').length;
    const accepted = complaints.filter(c => c.status === 'مقبول').length;
    const rejected = complaints.filter(c => c.status === 'مرفوض').length;
    cmpCharts.status = new Chart(statusCtx, {
      type: 'doughnut',
      data: { labels: ['معلق', 'مقبول', 'مرفوض'], datasets: [{ data: [pending, accepted, rejected], backgroundColor: ['#f59e0b','#16a34a','#dc2626'], borderWidth: 2 }] },
      options: { responsive: true, plugins: { legend: { position: 'bottom' } } },
    });
  }
  // Rating bar
  const ratingCtx = qs('#cmp-chart-rating');
  if (ratingCtx) {
    if (cmpCharts.rating) cmpCharts.rating.destroy();
    const counts = [0,0,0,0,0];
    complaints.forEach(c => { if (c.surveyRating >= 1 && c.surveyRating <= 5) counts[c.surveyRating - 1]++; });
    cmpCharts.rating = new Chart(ratingCtx, {
      type: 'bar',
      data: { labels: ['⭐','⭐⭐','⭐⭐⭐','⭐⭐⭐⭐','⭐⭐⭐⭐⭐'], datasets: [{ label: 'عدد التقييمات', data: counts, backgroundColor: ['#dc2626','#f59e0b','#eab308','#22c55e','#16a34a'] }] },
      options: { responsive: true, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } } },
    });
  }
  // Monthly trend
  const trendCtx = qs('#cmp-chart-trend');
  if (trendCtx) {
    if (cmpCharts.trend) cmpCharts.trend.destroy();
    const months = {};
    complaints.forEach(c => {
      const m = (c.createdAt || '').slice(0, 7);
      if (m) months[m] = (months[m] || 0) + 1;
    });
    const keys = Object.keys(months).sort().slice(-6);
    cmpCharts.trend = new Chart(trendCtx, {
      type: 'line',
      data: { labels: keys, datasets: [{ label: 'الشكاوى', data: keys.map(k => months[k]), borderColor: '#2d7a4f', backgroundColor: 'rgba(45,122,79,0.1)', fill: true, tension: 0.4 }] },
      options: { responsive: true, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } } },
    });
  }
}

function renderCmpNegAlert() {
  const negBox = qs('#cmp-neg-alert');
  if (!negBox) return;
  const neg = complaints.filter(c => c.surveyRating && c.surveyRating <= 2);
  if (!neg.length) { negBox.style.display = 'none'; return; }
  negBox.style.display = 'block';
  negBox.innerHTML = `<div class="card" style="border:2px solid var(--red);padding:14px">
    <div style="font-weight:700;color:var(--red);margin-bottom:10px">⚠️ شكاوى بتقييم سلبي (${neg.length})</div>
    ${neg.map(c => `<div style="border-bottom:1px solid var(--border);padding:6px 0;font-size:.85rem">
      <span class="badge badge-blue">${esc(c.complaintNo)}</span>
      ${'⭐'.repeat(c.surveyRating)} — ${esc(c.clientName || c.submittedBy)}:
      <em>${esc(c.surveyComment || '—')}</em>
    </div>`).join('')}
  </div>`;
}

// Modals
function openComplaintModal() {
  const txOptions = transactions.filter(t => !t.cancelled && t.type === 'مبيعات')
    .map(t => `<option value="${t._id}" data-ref="${esc(t.ref || t._id)}" data-client="${esc(t.client || '')}">${esc(t.ref || t._id)} — ${esc(t.client || '—')} (${fmtDate((t.date||'').slice(0,10))})</option>`)
    .join('');
  openModal(`<h3 style="margin-bottom:16px">شكوى جديدة</h3>
    <div class="form-group">
      <label class="form-label">الطلب المرتبط (اختياري)</label>
      <select id="cmp-tx-sel" style="width:100%" onchange="cmpTxChange(this)">
        <option value="">— اختر طلباً —</option>${txOptions}
      </select>
    </div>
    <div class="form-group">
      <label class="form-label">اسم العميل</label>
      <input type="text" id="cmp-client-input" class="form-input" placeholder="اسم العميل">
    </div>
    <div class="form-group">
      <label class="form-label">وصف الشكوى <span style="color:var(--red)">*</span></label>
      <textarea id="cmp-desc" rows="4" style="width:100%;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:8px 12px;color:var(--text);resize:vertical" placeholder="اكتب تفاصيل الشكوى..."></textarea>
    </div>
    <div style="text-align:left;margin-top:8px">
      <small class="text-muted">سيتم تسجيل اسم الموظف: <strong>${esc(currentUser?.name || currentUser?.username || '')}</strong></small>
    </div>
    <div class="flex gap-8" style="margin-top:16px;justify-content:flex-end">
      <button class="btn btn-outline" onclick="closeModal()">إلغاء</button>
      <button class="btn btn-primary" onclick="saveComplaint()">حفظ وإرسال</button>
    </div>`);
}

function cmpTxChange(sel) {
  const opt = sel.options[sel.selectedIndex];
  const client = opt ? (opt.getAttribute('data-client') || '') : '';
  const clientInput = qs('#cmp-client-input');
  if (clientInput && client) clientInput.value = client;
}

async function saveComplaint() {
  const txSel = qs('#cmp-tx-sel');
  const transactionId = txSel ? txSel.value : '';
  const txOpt = txSel ? txSel.options[txSel.selectedIndex] : null;
  const transactionRef = txOpt && transactionId ? (txOpt.getAttribute('data-ref') || transactionId) : '';
  const clientName = (qs('#cmp-client-input')?.value || '').trim();
  const description = (qs('#cmp-desc')?.value || '').trim();
  if (!description) { toast('يرجى كتابة وصف الشكوى', true); return; }
  try {
    const body = { description };
    if (transactionId) { body.transactionId = transactionId; body.transactionRef = transactionRef; }
    if (clientName) body.clientName = clientName;
    const res = await api('/complaints', { method: 'POST', body: JSON.stringify(body) });
    toast(`تم حفظ الشكوى رقم ${res.complaintNo}`);
    closeModal();
    await loadComplaints();
    buildSidebar();
    buildNotifications();
  } catch (e) { toast(e.message, true); }
}

function openResolveModal(id) {
  const c = complaints.find(x => x._id === id);
  if (!c) return;
  openModal(`<h3 style="margin-bottom:4px">قرار الإدارة</h3>
    <div style="margin-bottom:16px"><span class="badge badge-blue">${esc(c.complaintNo)}</span> — ${esc(c.clientName || c.submittedBy)}</div>
    <div style="background:var(--surface);border-radius:var(--radius);padding:10px;margin-bottom:16px;font-size:.9rem">${esc(c.description)}</div>
    <div class="form-group">
      <label class="form-label">القرار <span style="color:var(--red)">*</span></label>
      <select id="resolve-status" style="width:100%">
        <option value="مقبول">قبول الشكوى</option>
        <option value="مرفوض">رفض الشكوى</option>
      </select>
    </div>
    <div class="form-group">
      <label class="form-label">الإجراء المتخذ</label>
      <select id="resolve-action" style="width:100%">
        <option value="">— اختر —</option>
        <option value="استبدال">استبدال</option>
        <option value="استرداد">استرداد</option>
        <option value="تعويض">تعويض</option>
        <option value="رفض">رفض</option>
        <option value="أخرى">أخرى</option>
      </select>
    </div>
    <div class="form-group">
      <label class="form-label">ملاحظات الإدارة</label>
      <textarea id="resolve-note" rows="3" style="width:100%;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:8px 12px;color:var(--text);resize:vertical" placeholder="ملاحظات إضافية..."></textarea>
    </div>
    <div style="background:var(--primary-pale);border-radius:var(--radius);padding:10px;font-size:.85rem;margin-bottom:16px">
      💡 عند الحفظ سيتم إنشاء رابط استبيان لمشاركته مع العميل تلقائياً.
    </div>
    <div class="flex gap-8" style="justify-content:flex-end">
      <button class="btn btn-outline" onclick="closeModal()">إلغاء</button>
      <button class="btn btn-primary" onclick="resolveComplaint('${id}')">حفظ القرار</button>
    </div>`);
}

async function resolveComplaint(id) {
  const status = qs('#resolve-status').value;
  const managerAction = qs('#resolve-action').value;
  const actionNote = (qs('#resolve-note')?.value || '').trim();
  try {
    const res = await api(`/complaints/${id}/resolve`, {
      method: 'POST',
      body: JSON.stringify({ status, managerAction, actionNote }),
    });
    toast(`تم تحديث الشكوى — ${status}`);
    if (res.surveyToken) {
      const link = `${location.origin}/survey.html?token=${res.surveyToken}`;
      closeModal();
      openModal('<h3 style="margin-bottom:12px">رابط استبيان العميل</h3><p style="margin-bottom:12px;color:var(--muted)">شارك هذا الرابط مع العميل لتقييم تجربته:</p><div style="background:var(--surface2);border-radius:var(--radius);padding:12px;word-break:break-all;font-size:.85rem;user-select:all;margin-bottom:16px">' + esc(link) + '</div><div class="flex gap-8" style="justify-content:flex-end"><button class="btn btn-outline" onclick="closeModal()">إغلاق</button><button class="btn btn-primary" onclick="navigator.clipboard.writeText(' + "'" + esc(link) + "'" + ').then(()=>toast("تم نسخ الرابط"))">📋 نسخ الرابط</button></div>');
    } else {
      closeModal();
    }
    await loadComplaints();
    buildSidebar();
    buildNotifications();
  } catch (e) { toast(e.message, true); }
}

function viewComplaint(id) {
  const c = complaints.find(x => x._id === id);
  if (!c) return;
  const statusBadge = c.status === 'مقبول'
    ? `<span class="badge badge-green">مقبول</span>`
    : c.status === 'مرفوض'
      ? `<span class="badge badge-red">مرفوض</span>`
      : `<span class="badge badge-orange">معلق</span>`;
  const ratingHtml = c.surveyRating ? '⭐'.repeat(c.surveyRating) + ` (${c.surveyRating}/5)` : '—';
  const surveyLink = c.surveyToken
    ? `${location.origin}/survey.html?token=${c.surveyToken}` : null;
  openModal(`<h3 style="margin-bottom:4px">${esc(c.complaintNo)}</h3>
    <div style="margin-bottom:14px">${statusBadge} ${c.managerAction ? '<span class="badge badge-blue">' + esc(c.managerAction) + '</span>' : ''}</div>
    <table style="width:100%;font-size:.88rem;border-collapse:collapse">
      <tr><td style="padding:5px 8px;color:var(--muted);width:140px">الموظف المقدِّم</td><td>${esc(c.submittedBy)}</td></tr>
      <tr><td style="padding:5px 8px;color:var(--muted)">العميل</td><td>${esc(c.clientName || '—')}</td></tr>
      <tr><td style="padding:5px 8px;color:var(--muted)">الطلب</td><td>${esc(c.transactionRef || '—')}</td></tr>
      <tr><td style="padding:5px 8px;color:var(--muted)">تاريخ التقديم</td><td>${(c.createdAt||'').slice(0,16).replace('T',' ')}</td></tr>
      <tr><td style="padding:5px 8px;color:var(--muted)">الوصف</td><td style="white-space:pre-wrap">${esc(c.description)}</td></tr>
      ${c.resolvedBy ? '<tr><td style="padding:5px 8px;color:var(--muted)">المُعالِج</td><td>' + esc(c.resolvedBy) + '</td></tr>' : ''}
      ${c.resolvedAt ? '<tr><td style="padding:5px 8px;color:var(--muted)">تاريخ المعالجة</td><td>' + (c.resolvedAt||'').slice(0,16).replace('T',' ') + '</td></tr>' : ''}
      ${c.actionNote ? '<tr><td style="padding:5px 8px;color:var(--muted)">ملاحظات</td><td style="white-space:pre-wrap">' + esc(c.actionNote) + '</td></tr>' : ''}
      <tr><td style="padding:5px 8px;color:var(--muted)">تقييم العميل</td><td>${ratingHtml}</td></tr>
      ${c.surveyComment ? '<tr><td style="padding:5px 8px;color:var(--muted)">تعليق العميل</td><td style="white-space:pre-wrap">' + esc(c.surveyComment) + '</td></tr>' : ''}
      ${surveyLink ? '<tr><td style="padding:5px 8px;color:var(--muted)">رابط الاستبيان</td><td style="word-break:break-all;font-size:.8rem">' + esc(surveyLink) + '</td></tr>' : ''}
    </table>
    <div class="flex gap-8" style="margin-top:16px;justify-content:flex-end">
      ${surveyLink && !c.surveyCompletedAt ? '<button class="btn btn-outline" onclick="navigator.clipboard.writeText(' + "'" + esc(surveyLink) + "'" + ').then(()=>toast("تم النسخ"))">📋 نسخ رابط الاستبيان</button>' : ''}
      <button class="btn btn-outline" onclick="closeModal()">إغلاق</button>
    </div>`);
}

function copySurveyLink(token) {
  const link = `${location.origin}/survey.html?token=${token}`;
  navigator.clipboard.writeText(link).then(() => toast('تم نسخ رابط الاستبيان'));
}

async function deleteComplaint(id) {
  if (!confirm('هل تريد حذف هذه الشكوى؟')) return;
  try {
    await api(`/complaints/${id}`, { method: 'DELETE' });
    toast('تم الحذف');
    complaints = complaints.filter(c => c._id !== id);
    renderComplaints();
    renderCmpCharts();
    buildSidebar();
  } catch (e) { toast(e.message, true); }
}

function exportComplaintsExcel() {
  if (typeof XLSX === 'undefined') { toast('مكتبة التصدير غير محملة', true); return; }
  const rows = complaints.map(c => ({
    'رقم الشكوى': c.complaintNo,
    'الموظف': c.submittedBy,
    'العميل': c.clientName || '',
    'الطلب': c.transactionRef || '',
    'الوصف': c.description,
    'الحالة': c.status,
    'الإجراء': c.managerAction || '',
    'ملاحظات': c.actionNote || '',
    'المُعالِج': c.resolvedBy || '',
    'تاريخ المعالجة': (c.resolvedAt || '').slice(0, 16).replace('T', ' '),
    'تقييم العميل': c.surveyRating || '',
    'تعليق العميل': c.surveyComment || '',
    'تاريخ التقديم': (c.createdAt || '').slice(0, 16).replace('T', ' '),
  }));
  const ws = XLSX.utils.json_to_sheet(rows);
  const wb = XLSX.utils.book_new();
  XLSX.utils.book_append_sheet(wb, ws, 'Complaints');
  XLSX.writeFile(wb, `complaints_${today()}.xlsx`);
}

/* Smart Product Card */
let productCardData = null;
let productCardFilter = 'all'; // all, sales, purchases, returns
let productSuggestions = [];
let selectedSuggestionIndex = -1;

function showProductCard() {
  const modal = `
    <div style="padding:24px;width:100%;max-width:500px">
      <h3 style="margin:0 0 20px 0;color:var(--primary);text-align:right">🔍 البحث عن المنتج</h3>

      <div style="position:relative">
        <input
          type="text"
          id="product-search-input"
          placeholder="ابحث باستخدام الكود أو الاسم..."
          style="
            width:100%;
            padding:12px 16px;
            border:2px solid var(--border);
            border-radius:8px;
            font-size:1rem;
            font-family:inherit;
            background:var(--surface);
            color:var(--text);
            direction:rtl
          "
          oninput="filterProductSuggestions(this.value)"
          onkeydown="handleProductSearchKeydown(event)"
          autofocus
        >

        <!-- Suggestions Dropdown -->
        <div id="product-suggestions" style="
          position:absolute;
          top:100%;
          left:0;
          right:0;
          background:var(--surface2);
          border:1px solid var(--border);
          border-top:none;
          border-radius:0 0 8px 8px;
          max-height:300px;
          overflow-y:auto;
          z-index:1000;
          display:none;
          margin-top:-1px
        "></div>
      </div>

      <div style="display:flex;gap:8px;margin-top:20px;justify-content:flex-end">
        <button class="btn btn-primary" onclick="executeProductCardSearch()">بحث</button>
        <button class="btn btn-outline" onclick="closeModal()">إلغاء</button>
      </div>

      <div style="margin-top:16px;padding:12px;background:rgba(59,130,246,.1);border-right:3px solid var(--blue);border-radius:4px;font-size:.85rem;color:var(--muted);text-align:right">
        💡 ابدأ بالكتابة لرؤية الاقتراحات - اختر منتجاً من القائمة أو اضغط Enter للبحث
      </div>
    </div>
  `;

  openModal(modal, 'width:100%;max-width:500px');
  setTimeout(() => qs('#product-search-input')?.focus(), 100);
  loadProductSuggestionsData();
}

async function loadProductSuggestionsData() {
  try {
    productSuggestions = products.map(p => ({
      _id: p._id,
      code: p.code,
      name: p.name,
      displayText: `${p.code} - ${p.name}`
    })) || [];
  } catch (e) {
    console.error('Failed to load product suggestions:', e);
  }
}

function filterProductSuggestions(query) {
  const q = query.trim().toLowerCase();
  const suggestionsDiv = qs('#product-suggestions');
  selectedSuggestionIndex = -1;

  if (!q) {
    suggestionsDiv.style.display = 'none';
    return;
  }

  const filtered = productSuggestions.filter(p =>
    p.code.toLowerCase().includes(q) || p.name.toLowerCase().includes(q)
  ).slice(0, 8);

  if (filtered.length === 0) {
    suggestionsDiv.innerHTML = '<div style="padding:12px;text-align:center;color:var(--muted)">لا توجد نتائج</div>';
    suggestionsDiv.style.display = 'block';
    return;
  }

  suggestionsDiv.innerHTML = filtered.map((p, idx) => `
    <div
      class="product-suggestion"
      data-idx="${idx}"
      style="
        padding:10px 12px;
        border-bottom:1px solid var(--border);
        cursor:pointer;
        text-align:right;
        transition:background .2s;
        background:var(--surface2)
      "
      onmouseover="this.style.background='var(--surface3)'"
      onmouseout="this.style.background='var(--surface2)'"
      onclick="selectProductSuggestion('${esc(p.code)}')"
    >
      <div style="font-weight:600;color:var(--primary)">${esc(p.code)}</div>
      <div style="font-size:.85rem;color:var(--muted);margin-top:2px">${esc(p.name)}</div>
    </div>
  `).join('');

  suggestionsDiv.style.display = 'block';
}

function handleProductSearchKeydown(e) {
  const suggestionsDiv = qs('#product-suggestions');
  const items = qsa('.product-suggestion');

  if (e.key === 'ArrowDown') {
    e.preventDefault();
    selectedSuggestionIndex = Math.min(selectedSuggestionIndex + 1, items.length - 1);
    updateSuggestionHighlight(items);
  } else if (e.key === 'ArrowUp') {
    e.preventDefault();
    selectedSuggestionIndex = Math.max(selectedSuggestionIndex - 1, -1);
    updateSuggestionHighlight(items);
  } else if (e.key === 'Enter') {
    e.preventDefault();
    if (selectedSuggestionIndex >= 0 && items[selectedSuggestionIndex]) {
      items[selectedSuggestionIndex].click();
    } else {
      executeProductCardSearch();
    }
  } else if (e.key === 'Escape') {
    closeModal();
  }
}

function updateSuggestionHighlight(items) {
  items.forEach((item, idx) => {
    if (idx === selectedSuggestionIndex) {
      item.style.background = 'var(--blue)';
      item.style.color = 'white';
      item.scrollIntoView({ block: 'nearest' });
    } else {
      item.style.background = 'var(--surface2)';
      item.style.color = 'var(--text)';
    }
  });
}

function selectProductSuggestion(code) {
  qs('#product-search-input').value = code;
  qs('#product-suggestions').style.display = 'none';
  setTimeout(() => executeProductCardSearch(), 50);
}

async function executeProductCardSearch() {
  const searchInput = qs('#product-search-input')?.value?.trim();
  if (!searchInput) {
    toast('الرجاء إدخال كود أو اسم المنتج', true);
    return;
  }

  try {
    closeModal();
    toast('جاري التحميل...', false);
    const data = await api(`/products/analytics/card/${encodeURIComponent(searchInput)}`);
    productCardData = data;
    productCardFilter = 'all';
    renderProductCard();
    toast('');
  } catch (e) {
    toast('خطأ: ' + (e.message || 'فشل تحميل بيانات المنتج'), true);
  }
}

function renderProductCard() {
  if (!productCardData) return;

  const data = productCardData;
  const perf = data.performance;
  const rankColor = perf.rank === 'Successful' ? 'var(--green)' : perf.rank === 'Average' ? 'var(--orange)' : 'var(--red)';
  const rankEmoji = perf.rank === 'Successful' ? '🌟' : perf.rank === 'Average' ? '⚠️' : '📉';

  const html = `
    <button class="inv-close" onclick="closeProductCard()" style="position:absolute;top:12px;right:12px;z-index:1">✕</button>
    <div style="padding:20px;max-height:85vh;overflow-y:auto">
      <!-- Header -->
      <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:20px;border-bottom:2px solid var(--border);padding-bottom:12px">
        <div>
          <h2 style="margin:0;color:var(--primary);font-size:1.6rem">${esc(data.product.name)}</h2>
          <div style="font-size:.9rem;color:var(--muted);margin-top:4px">
            <strong>الكود:</strong> ${esc(data.product.code)} ·
            <strong>سعر البيع:</strong> ${fmtJ(data.product.sellPrice)} ·
            <strong>سعر الشراء:</strong> ${fmtJ(data.product.buyPrice)}
          </div>
        </div>
        <div style="text-align:left;padding:12px;background:var(--surface2);border-radius:8px;border-right:3px solid ${rankColor}">
          <div style="font-size:1.1rem;font-weight:700;color:${rankColor}">${rankEmoji} ${esc(perf.rank)}</div>
          <div style="font-size:.85rem;color:var(--muted);margin-top:6px">${esc(perf.reason)}</div>
          <div style="font-size:1rem;font-weight:700;color:var(--primary);margin-top:6px">نقاط الأداء: ${perf.score}%</div>
        </div>
      </div>

      <!-- Summary Cards -->
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:12px;margin-bottom:20px">
        <div style="padding:14px;background:var(--surface2);border-radius:8px;border-right:3px solid var(--green)">
          <div style="font-size:.8rem;color:var(--muted);margin-bottom:6px">🛒 فواتير المبيعات</div>
          <div style="font-weight:700;color:var(--green);font-size:1.3rem">${data.summary.totalSaleInvoices}</div>
          <div style="font-size:.85rem;color:var(--text);margin-top:4px">الكمية: ${fmtN(data.summary.totalQuantitySold)}</div>
          <div style="font-size:.85rem;color:var(--green);font-weight:600;margin-top:4px">${fmtJ(data.summary.totalRevenueFromSales)}</div>
        </div>
        <div style="padding:14px;background:var(--surface2);border-radius:8px;border-right:3px solid var(--blue)">
          <div style="font-size:.8rem;color:var(--muted);margin-bottom:6px">📦 فواتير الشراء</div>
          <div style="font-weight:700;color:var(--blue);font-size:1.3rem">${data.summary.totalPurchaseInvoices}</div>
          <div style="font-size:.85rem;color:var(--text);margin-top:4px">الكمية: ${fmtN(data.summary.totalQuantityPurchased)}</div>
          <div style="font-size:.85rem;color:var(--blue);font-weight:600;margin-top:4px">${fmtJ(data.summary.totalCostFromPurchases)}</div>
        </div>
        <div style="padding:14px;background:var(--surface2);border-radius:8px;border-right:3px solid var(--red)">
          <div style="font-size:.8rem;color:var(--muted);margin-bottom:6px">🔄 المرتجعات</div>
          <div style="font-weight:700;color:var(--red);font-size:1.3rem">${data.summary.totalReturnInvoices}</div>
          <div style="font-size:.85rem;color:var(--text);margin-top:4px">الكمية: ${fmtN(data.summary.totalQuantityReturned)}</div>
          <div style="font-size:.85rem;color:var(--red);font-weight:600;margin-top:4px">−${fmtJ(data.summary.totalLossFromReturns)}</div>
        </div>
        <div style="padding:14px;background:var(--surface2);border-radius:8px;border-right:3px solid var(--accent)">
          <div style="font-size:.8rem;color:var(--muted);margin-bottom:6px">💰 هامش الربح</div>
          <div style="font-weight:700;color:var(--accent);font-size:1.3rem">${data.summary.profitMargin}%</div>
          <div style="font-size:.85rem;color:var(--text);margin-top:4px">صافي الربح</div>
          <div style="font-size:.85rem;color:var(--accent);font-weight:600;margin-top:4px">${fmtJ(data.summary.totalRevenueFromSales - data.summary.totalCostFromPurchases)}</div>
        </div>
      </div>

      <!-- Tabs for invoice types -->
      <div style="display:flex;gap:8px;margin-bottom:16px;border-bottom:1px solid var(--border);padding-bottom:8px">
        <button class="${productCardFilter === 'all' ? 'btn btn-primary btn-sm' : 'btn btn-outline btn-sm'}" onclick="setProductCardFilter('all')">
          📊 الكل (${data.invoices.sales.length + data.invoices.purchases.length + data.invoices.returns.length})
        </button>
        <button class="${productCardFilter === 'sales' ? 'btn btn-primary btn-sm' : 'btn btn-outline btn-sm'}" onclick="setProductCardFilter('sales')">
          🛒 مبيعات (${data.invoices.sales.length})
        </button>
        <button class="${productCardFilter === 'purchases' ? 'btn btn-primary btn-sm' : 'btn btn-outline btn-sm'}" onclick="setProductCardFilter('purchases')">
          📦 شراء (${data.invoices.purchases.length})
        </button>
        <button class="${productCardFilter === 'returns' ? 'btn btn-primary btn-sm' : 'btn btn-outline btn-sm'}" onclick="setProductCardFilter('returns')">
          🔄 مرتجع (${data.invoices.returns.length})
        </button>
      </div>

      <!-- Invoices Table -->
      ${renderProductCardInvoices()}

      <!-- Actions -->
      <div style="display:flex;gap:8px;margin-top:20px;padding-top:12px;border-top:1px solid var(--border)">
        <button class="btn btn-primary btn-sm" onclick="exportProductCard()">📥 تصدير Excel</button>
        <button class="btn btn-outline btn-sm" onclick="window.print()">🖨️ طباعة</button>
        <button class="btn btn-outline btn-sm" onclick="closeProductCard()">إغلاق</button>
      </div>
    </div>
  `;

  openModal(html, 'max-width:900px;max-height:90vh');
}

function renderProductCardInvoices() {
  if (!productCardData) return '';

  const invoices = productCardFilter === 'all'
    ? [...productCardData.invoices.sales, ...productCardData.invoices.purchases, ...productCardData.invoices.returns]
    : productCardFilter === 'sales'
    ? productCardData.invoices.sales
    : productCardFilter === 'purchases'
    ? productCardData.invoices.purchases
    : productCardData.invoices.returns;

  if (!invoices.length) {
    return '<div style="padding:20px;text-align:center;color:var(--muted)">لا توجد فواتير من هذا النوع</div>';
  }

  const typeColor = (type) => type === 'sales' ? 'var(--green)' : type === 'purchase' ? 'var(--blue)' : 'var(--red)';
  const typeLabel = (type) => type === 'sales' ? '🛒 مبيعات' : type === 'purchase' ? '📦 شراء' : '🔄 مرتجع';

  return `
    <div style="border:1px solid var(--border);border-radius:8px;overflow:hidden">
      <table style="width:100%;border-collapse:collapse;font-size:.9rem">
        <thead style="background:var(--surface2)">
          <tr>
            <th style="padding:12px;text-align:right;border-bottom:1px solid var(--border)">النوع</th>
            <th style="padding:12px;text-align:right;border-bottom:1px solid var(--border)">الرقم المرجعي</th>
            <th style="padding:12px;text-align:right;border-bottom:1px solid var(--border)">العميل</th>
            <th style="padding:12px;text-align:right;border-bottom:1px solid var(--border)">التاريخ</th>
            <th style="padding:12px;text-align:right;border-bottom:1px solid var(--border)">الكمية</th>
            <th style="padding:12px;text-align:right;border-bottom:1px solid var(--border)">السعر</th>
            <th style="padding:12px;text-align:right;border-bottom:1px solid var(--border)">الإجمالي</th>
            <th style="padding:12px;text-align:right;border-bottom:1px solid var(--border)">الحالة</th>
          </tr>
        </thead>
        <tbody>
          ${invoices.map(inv => `
            <tr style="border-bottom:1px solid var(--border)">
              <td style="padding:10px;color:${typeColor(inv.type)};font-weight:600">${typeLabel(inv.type)}</td>
              <td style="padding:10px;font-weight:600;direction:ltr">#${esc(inv.ref)}</td>
              <td style="padding:10px">${esc(inv.client)}</td>
              <td style="padding:10px">${fmtDate(inv.date)}</td>
              <td style="padding:10px;text-align:center">${fmtN(inv.quantity)}</td>
              <td style="padding:10px;text-align:left">${fmtJ(inv.unitPrice)}</td>
              <td style="padding:10px;font-weight:600;color:${typeColor(inv.type)}">${fmtJ(inv.totalPrice)}</td>
              <td style="padding:10px"><span class="badge" style="font-size:.7rem">${esc(inv.status)}</span></td>
            </tr>
          `).join('')}
        </tbody>
      </table>
    </div>
  `;
}

function setProductCardFilter(filter) {
  productCardFilter = filter;
  renderProductCard();
}

function exportProductCard() {
  if (!productCardData) return;
  const data = productCardData;
  const allInvoices = [
    ...data.invoices.sales.map(inv => ({
      'النوع': 'مبيعات',
      'الرقم المرجعي': inv.ref,
      'العميل': inv.client,
      'التاريخ': inv.date,
      'الكمية': inv.quantity,
      'السعر': inv.unitPrice,
      'الإجمالي': inv.totalPrice,
      'الحالة': inv.status,
    })),
    ...data.invoices.purchases.map(inv => ({
      'النوع': 'شراء',
      'الرقم المرجعي': inv.ref,
      'العميل': inv.client,
      'التاريخ': inv.date,
      'الكمية': inv.quantity,
      'السعر': inv.unitPrice,
      'الإجمالي': inv.totalPrice,
      'الحالة': inv.status,
    })),
    ...data.invoices.returns.map(inv => ({
      'النوع': 'مرتجع',
      'الرقم المرجعي': inv.ref,
      'العميل': inv.client,
      'التاريخ': inv.date,
      'الكمية': inv.quantity,
      'السعر': inv.unitPrice,
      'الإجمالي': inv.totalPrice,
      'الحالة': inv.status,
    })),
  ];

  const ws = XLSX.utils.json_to_sheet(allInvoices);
  const wb = XLSX.utils.book_new();
  XLSX.utils.book_append_sheet(wb, ws, 'الفواتير');
  XLSX.writeFile(wb, `product_${data.product.code}_${today()}.xlsx`);
  toast('تم تصدير البيانات بنجاح');
}

function closeProductCard() {
  qs('#modal-overlay').classList.remove('active');
  productCardData = null;
}

/* Init */
(async function init() {
  const isAuthed = await checkAuth();
  if (isAuthed) {
    showApp();
    initReferenceClickHandlers();
  }
  else { qs('#login-page').style.display = 'flex'; }
})();
</script>
</body>
</html>
